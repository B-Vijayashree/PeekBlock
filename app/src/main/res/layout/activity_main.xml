<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PeekBlock"
                android:textSize="36sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:textColor="#1A73E8"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI-Powered Privacy Shield"
                android:textSize="14sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.2"
                android:textColor="#5F6368"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Professional Dashboard Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                android:layout_marginBottom="24dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:background="@android:color/white">

                    <TextView
                        android:id="@+id/tvSecurityHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SECURITY OVERVIEW"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#5F6368"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Threat Level Indicator -->
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/riskProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        app:indicatorSize="120dp"
                        app:trackThickness="10dp"
                        app:trackColor="#F1F3F4"
                        app:indicatorColor="#388E3C"
                        android:progress="0"
                        app:layout_constraintTop_toBottomOf="@id/tvSecurityHeader"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        app:layout_constraintTop_toTopOf="@id/riskProgress"
                        app:layout_constraintBottom_toBottomOf="@id/riskProgress"
                        app:layout_constraintStart_toStartOf="@id/riskProgress"
                        app:layout_constraintEnd_toEndOf="@id/riskProgress">

                        <TextView
                            android:id="@+id/tvFraudPercentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="#202124" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Risk"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:textColor="#5F6368" />
                    </LinearLayout>

                    <View
                        android:id="@+id/divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F3F4"
                        android:layout_marginTop="24dp"
                        app:layout_constraintTop_toBottomOf="@id/riskProgress" />

                    <LinearLayout
                        android:id="@+id/layoutStats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/divider">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Proximity"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="#5F6368" />
                            <TextView
                                android:id="@+id/tvProximity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="N/A"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="#202124"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Privacy State"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="#5F6368" />
                            <TextView
                                android:id="@+id/tvStatusLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SAFE"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="#388E3C"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Local processing active. No data stored."
                        android:textSize="11sp"
                        android:textColor="#9AA0A6"
                        android:fontFamily="sans-serif-light"
                        android:textStyle="italic"
                        android:textAlignment="center"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/layoutStats" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Camera Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cameraCard"
                android:layout_width="180dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">
                <androidx.camera.view.PreviewView
                    android:id="@+id/previewView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:scaleType="fillCenter" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Settings Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@android:color/white">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchPrivacy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Shield Protection"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alert Strategies (Enable multiple)"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#5F6368"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchBlur"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Full Screen Blur"
                        android:fontFamily="sans-serif"
                        android:checked="true" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSideBlur"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dynamic Side Blur"
                        android:fontFamily="sans-serif" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchToast"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tactile Toast"
                        android:fontFamily="sans-serif" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchVibrate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Silent Vibration"
                        android:fontFamily="sans-serif" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Overlay UI -->
    <View
        android:id="@+id/blurOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:elevation="100dp" />

    <View
        android:id="@+id/sideBlurLeft"
        android:layout_width="120dp"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:elevation="100dp"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:id="@+id/sideBlurRight"
        android:layout_width="120dp"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:elevation="100dp"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/warningText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PRIVACY BREACH DETECTED"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone"
        android:elevation="101dp"
        android:background="#AAFF0000"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>